{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                n.id,\n                n.event_id,\n                n.event_type,\n                n.status,\n                n.retry_count,\n                n.total_attempts,\n                n.last_error,\n                n.payload,\n                n.event_timestamp,\n                n.created_at,\n                n.updated_at,\n                e.recipient_email,\n                e.recipient_name,\n                e.from_override,\n                e.sender_account,\n                e.send_mode,\n                e.cc,\n                e.bcc,\n                e.attachments\n            FROM notification_log n\n            JOIN email_notification_log e ON e.notification_id = n.id\n            WHERE n.event_id    = $1\n              AND n.channel     = $2\n              AND n.recipient_id = $3\n            ",
