{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                n.event_type,\n                n.payload,\n                n.event_timestamp,\n                n.created_at,\n                e.from_override,\n                e.sender_account,\n                e.send_mode,\n                e.group_retry_mode,\n                e.attachments,\n                e.cc,\n                e.bcc\n            FROM notification_log n\n            JOIN email_notification_log e ON e.notification_id = n.id\n            WHERE n.event_id = $1\n              AND n.channel  = $2\n            ORDER BY n.created_at\n            ",
