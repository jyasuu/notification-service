# Copy to .env and adjust for your environment.
# All values shown are defaults that apply when the variable is unset.

# ── PostgreSQL (notification-service DB) ──────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=notifications
POSTGRES_PORT=5432

# ── PostgreSQL (business service DB — outbox profile only) ────────────────────
BUSINESS_POSTGRES_USER=postgres
BUSINESS_POSTGRES_PASSWORD=postgres
BUSINESS_POSTGRES_DB=business
BUSINESS_POSTGRES_PORT=5433
# Set this to activate the outbox worker inside the notification service:
# NS_OUTBOX_DATABASE_URL=postgres://postgres:postgres@business-postgres:5432/business

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── Notification service ──────────────────────────────────────────────────────
SERVICE_PORT=8080
RUST_LOG=info

# AMQP topology
AMQP_QUEUE=email.requested
AMQP_EXCHANGE=notifications
AMQP_ROUTING_KEY=email.requested
AMQP_MAX_RETRIES=3
AMQP_RETRY_BASE_MS=1000
AMQP_MAX_CONCURRENCY=10

# Outbox worker (optional — leave unset to disable)
# Set to the connection string of your business service's database.
# NS_OUTBOX_DATABASE_URL=postgres://postgres:postgres@postgres:5432/business
# AMQP_OUTBOX_POLL_INTERVAL_MS=1000
# AMQP_OUTBOX_BATCH_SIZE=50

# ── Mail server rate limiting ─────────────────────────────────────────────────
# Set to 0 to disable. Check your provider's documented limits.
NS_RATE_LIMIT__EMAILS_PER_SECOND=10
NS_RATE_LIMIT__BURST_SIZE=20

# ── Recipient filter (block / allow-list) ────────────────────────────────────
# JSON arrays. Leave empty for passthrough (no filtering).
# NS_FILTER__BLOCKED_EMAILS='["unsubscribed@example.com"]'
# NS_FILTER__BLOCKED_DOMAINS='["competitor.com"]'
# Allowlist mode — only these addresses/domains receive email (useful for staging):
# NS_FILTER__ALLOWED_DOMAINS='["yourcompany.com"]'
# NS_FILTER__ALLOWED_EMAILS='["qa@external.com"]'

# ── Email backend: smtp | webhook ─────────────────────────────────────────────
MAILER_BACKEND=smtp

# SMTP (used when MAILER_BACKEND=smtp)
SMTP_HOST=mailpit       # swap to your real SMTP host in production
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
SMTP_FROM_NAME=Notification Service

# Webhook (used when MAILER_BACKEND=webhook)
# MAILER_BACKEND=webhook
# WEBHOOK_URL=https://hooks.example.com/email
# WEBHOOK_AUTH_TOKEN=

# ── Mailpit (dev profile only) ────────────────────────────────────────────────
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ── Observability (observability profile only) ────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASS=admin
